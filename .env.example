PORT=3000
ANTHROPIC_API_KEY=your_key_here
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_key
QURAN_API_BASE=https://api.quran.com/api/v4
NODE_ENV=development

# Optional — enables the semantic search (RAG) layer in
# semanticSearch.service.ts. Without this, the app runs fine on the
# curated emotion taxonomy alone (see emotionTaxonomy.ts).
# Get a key at https://dash.voyageai.com — Anthropic's recommended
# embeddings partner (Claude itself has no embeddings endpoint).
VOYAGE_API_KEY=your_voyage_key_here
